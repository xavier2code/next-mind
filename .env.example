# Database
DATABASE_URL=postgresql://user:password@localhost:5432/nextmind

# Authentication
AUTH_SECRET=your-secret-key-min-32-chars
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# LLM API Keys
QWEN_API_KEY=your-qwen-api-key
GLM_API_KEY=your-glm-api-key
MINIMAX_API_KEY=your-minimax-api-key

# MCP Tool Execution Security
# These control the user/group context for bash command execution
# Tools run with these privileges (non-root for security)
# Defaults to 1000 (typical first non-root user on Linux/macOS)
MCP_UID=1000
MCP_GID=1000

# Storage (Phase 7)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./data/uploads
# S3 storage (uncomment to use)
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=
# S3_BUCKET=
# S3_REGION=auto
